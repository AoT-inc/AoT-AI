  "_mcp_tools": {
    "_comment": "MCP virtual tools for function lifecycle management. Call via virtual_tool_call.",

    "get_device_measurements": {
      "description": "Returns all measurement channels (measurement_id, channel, measurement, unit) for a given device_id. Use this to resolve measurement IDs needed for select_measurement params in create_function or modify_function_options.",
      "params": {
        "device_id": {"type": "string", "required": true, "desc": "unique_id of the Input or Function device"}
      },
      "returns": {"device_id": "string", "measurements": [{"measurement_id": "string", "channel": "int", "measurement": "string", "unit": "string"}]},
      "example": "get_device_measurements(device_id='abc123')"
    },

    "create_function": {
      "description": "Creates a new function controller. Requires human approval. After creation the function is automatically activated in the daemon.",
      "params": {
        "function_type": {"type": "string", "required": true, "desc": "Function type key, e.g. 'AoT_VPD', 'conditional_conditional', 'pid_pid', 'trigger_timer_duration'"},
        "name": {"type": "string", "required": false, "desc": "Display name for the function"},
        "params": {"type": "object", "required": false, "desc": "custom_options overrides. For select_measurement fields use 'device_id,measurement_id' string."}
      },
      "returns": {"function_id": "string", "name": "string", "function_type": "string", "status": "created"},
      "workflow": [
        "1. Call search_devices or get_device_list to find the target Input (e.g. weather sensor)",
        "2. Call get_device_measurements(device_id) to get temperature/humidity measurement_ids",
        "3. Call create_function with function_type and params containing 'device_id,measurement_id' strings",
        "4. Optionally call modify_function_options to adjust additional settings"
      ],
      "vpd_example": {
        "function_type": "AoT_VPD",
        "name": "1포장 VPD",
        "params": {
          "select_measurement_temperature_c": "weather_input_id,temp_measurement_id",
          "select_measurement_humidity": "weather_input_id,humidity_measurement_id",
          "period": 60,
          "leaf_temp_offset": -1.5
        }
      }
    },

    "modify_function_options": {
      "description": "Updates custom_options of an existing function and reloads it in the daemon. Requires human approval.",
      "params": {
        "function_id": {"type": "string", "required": true, "desc": "unique_id of the function to modify"},
        "params": {"type": "object", "required": true, "desc": "Dict of custom_option_id → new_value pairs to update"}
      },
      "returns": {"status": "updated", "function_id": "string", "updated_keys": ["string"]}
    }
  }
}
