{
  "DaemonControl": {
    "description": "RPC client to communicate with the AoT daemon (via Pyro5). Used for real-time control and synchronization.",
    "methods": {
      "check_daemon": {
        "description": "Checks if the daemon and its controllers are active.",
        "returns": "str ('GOOD' or error message)"
      },
      "controller_activate": {
        "params": [
          {
            "id": "controller_id",
            "type": "str",
            "description": "Unique ID of the controller to activate."
          }
        ],
        "returns": "bool/str status"
      },
      "controller_deactivate": {
        "params": [
          {
            "id": "controller_id",
            "type": "str",
            "description": "Unique ID of the controller to deactivate."
          }
        ],
        "returns": "bool/str status"
      },
      "output_on": {
        "params": [
          {
            "id": "output_id",
            "type": "str"
          },
          {
            "id": "output_type",
            "type": "str",
            "description": "Options: 'sec' (on for duration), 'pwm' (set duty cycle)."
          },
          {
            "id": "amount",
            "type": "float",
            "description": "Seconds or duty cycle percentage."
          },
          {
            "id": "output_channel",
            "type": "int",
            "description": "Channel index for multi-channel devices."
          }
        ]
      },
      "output_off": {
        "params": [
          {
            "id": "output_id",
            "type": "str"
          },
          {
            "id": "output_channel",
            "type": "int"
          }
        ]
      },
      "pid_set": {
        "params": [
          {
            "id": "pid_id",
            "type": "str"
          },
          {
            "id": "setting",
            "type": "str",
            "description": "Options: 'setpoint', 'kp', 'ki', 'kd', 'integrator', 'derivator'."
          },
          {
            "id": "value",
            "type": "float"
          }
        ]
      },
      "trigger_action": {
        "params": [
          {
            "id": "action_id",
            "type": "str"
          },
          {
            "id": "value",
            "type": "dict",
            "description": "Optional values to pass to the action."
          }
        ]
      },
      "input_force_measurements": {
        "params": [
          {
            "id": "input_id",
            "type": "str"
          }
        ],
        "description": "Forces the input controller to acquire a new measurement immediately."
      }
    }
  },
  "REST_API": {
    "auth": "Basic Auth or Session Cookie",
    "endpoints": {
      "GET /api/v1/measurement/latest/{input_id}": "Retrieve the most recent measurement value.",
      "POST /api/v1/controller/activate/{id}": "Activate a controller via REST.",
      "POST /api/v1/output/on/{id}": "Turn an output on via REST.",
      "POST /api/v1/action/trigger/{id}": "Trigger an action via REST."
    }
  }
}
