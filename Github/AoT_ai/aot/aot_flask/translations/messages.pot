#: config_translations_docs.py:55
msgid "Information"
msgstr ""

#: config_translations_docs.py:56
msgid ""
"See the [README](https://github.com/AoT-inc/AoT-AI#uses) for features, "
"projects using AoT, screenshots, and other information."
