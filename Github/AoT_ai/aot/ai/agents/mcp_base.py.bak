# coding=utf-8
import logging
import json
from aot.ai.base_ai import AbstractAI

logger = logging.getLogger(__name__)

class BaseMCP_AI(AbstractAI):
    """
    Base class for MCP-specialized agents.
    Does NOT inherit from a specific engine (like Gemini).
    Instead, it wraps an internal LLM engine for reasoning,
    while maintaining its specialized MCP identity.
    """
    def __init__(self, agent_config):
        super().__init__(agent_config)
        
        # 1. Determine which LLM brain to use for reasoning
        # v16: reasoning_entry_id allows using an existing AI Service Entry as the brain.
        try:
            options = json.loads(agent_config.custom_options_json) if agent_config.custom_options_json else {}
        except:
            options = {}
            
        self.reasoning_entry_id = options.get('reasoning_entry_id', '')
        self.llm_provider = options.get('llm_provider', 'gemini') # Fallback for old configs
        self.llm_model = options.get('llm_model', '') # Optional override
        
        # 2. Instantiate the internal reasoning engine
        # Pass the original agent_config but we will proxy the entry for the brain
        self._brain = self._init_brain(agent_config)
        
        # 3. Setup specialized system prompt
        specialty = getattr(self, 'MCP_SPECIALTY', 'General Tool Assistance')
        mcp_id = agent_config.unique_id # Linked by sharing the same unique_id
        
        self.mcp_instruction = (
            f"\n\n### [Specialist Context: MCP Server] ###\n"
            f"You are a specialized expert in: {specialty}\n"
            f"You have direct access to a dedicated MCP Server (ID: {mcp_id}).\n"
            f"When the user asks for actions related to your specialty, you MUST prefer using tools "
            f"provided by your MCP server via 'mcp_tool_call' with 'target_id'='{mcp_id}'.\n"
        )
        
        # Inject mcp instruction into the brain's system prompt
        if self._brain:
            orig_system = self._brain.system_prompt or ""
            if self.mcp_instruction not in orig_system:
                self._brain.system_prompt = orig_system + self.mcp_instruction

    def _init_brain(self, agent_config):
        """Helper to get the appropriate engine class based on selected reasoning brain."""
        from aot.services.ai_agent_service import ENGINE_REGISTRY
        from aot.databases.models.ai import AIEntry
        import copy

        target_provider = self.llm_provider
        target_entry = agent_config.entry
        
        # v6.3.2: Intelligent default brain selection for MCP agents
        if not self.reasoning_entry_id:
            # Check if current entry has a key (unlikely for MCP)
            if not target_entry.api_key:
                logger.info(f"[{self.__class__.__name__}] MCP Entry has no API key. Searching for default LLM Provider...")
                # v12.3: Role-based brain selection. Follow the 'executor' or 'supervisor' agent.
                from aot.databases.models.ai import AIAgent
                leader_agent = AIAgent.query.filter(
                    AIAgent.is_activated == True,
                    AIAgent.pipeline_role.in_(['executor', 'supervisor']),
                    ~AIAgent.role.startswith('mcp_') # Don't follow another MCP
                ).first()
                
                if leader_agent and leader_agent.entry and leader_agent.entry.api_key:
                    best_entry = leader_agent.entry
                    logger.info(f"[{self.__class__.__name__}] Auto-following Leader Brain: {leader_agent.name} -> {best_entry.name}")
                else:
                    # Final fallback: any entry with a key
                    best_entry = AIEntry.query.filter(
                        AIEntry.api_key != '',
                        AIEntry.model_type.in_(['gemini', 'groq', 'openai'])
                    ).order_by(AIEntry.is_activated.desc()).first()
                
                if best_entry:
                    logger.info(f"[{self.__class__.__name__}] Selected Reasoning Brain: {best_entry.name} ({best_entry.model_type}) - Key length: {len(best_entry.api_key)}")
                    target_provider = best_entry.model_type
                    target_entry = best_entry
                else:
                    logger.warning(f"[{self.__class__.__name__}] No valid LLM Provider found for MCP brain.")

        # v16: If a specific reasoning entry is selected, use its configuration
        if self.reasoning_entry_id:
            reasoning_entry = AIEntry.query.filter_by(unique_id=self.reasoning_entry_id).first()
            if reasoning_entry:
                target_provider = reasoning_entry.model_type
                target_entry = reasoning_entry
                logger.info(f"[{self.__class__.__name__}] Using Reasoning Brain Entry: {reasoning_entry.name} ({target_provider})")
            else:
                logger.warning(f"[{self.__class__.__name__}] Selected Reasoning Brain Entry {self.reasoning_entry_id} not found. Falling back.")

        registry_entry = ENGINE_REGISTRY.get(target_provider)
        if not registry_entry:
            registry_entry = ENGINE_REGISTRY.get('gemini')
            
        if registry_entry:
            engine_class, _ = registry_entry
            
            try:
                # We need to simulate an AIAgent object that points to the reasoning entry
                # but preserve the actual MCP agent's prompt/options identity.
                # However, many engines (Gemini, OpenAI) just need agent_config.entry for AUTH.
                # So we create a shallow copy of config and swap the entry.
                # v16.1: Use SimpleNamespace instead of copy.copy(agent_config).
                # Shallow copy of a SQLAlchemy model still shares the session state,
                # so 'proxy_config.entry = target_entry' was actually mutating the original 
                # AIAgent's entry_id in the DB. This caused all MCP agents to become LLMs.
                from types import SimpleNamespace
                proxy_config = SimpleNamespace(
                    unique_id=agent_config.unique_id,
                    name=agent_config.name,
                    role=agent_config.role,
                    system_prompt=agent_config.system_prompt,
                    temperature=agent_config.temperature,
                    max_tokens=agent_config.max_tokens,
                    model_tier=agent_config.model_tier,
                    custom_options_json=agent_config.custom_options_json,
                    entry=target_entry
                )
                
                engine = engine_class(proxy_config)
                
                # v12.2: Ensure brain uses a valid LLM model name. 
                # If the agent's model name is an MCP specialty (places, default, virtual_mcp), 
                # revert to the provider's stable default.
                if not self.llm_model:
                    if engine.model_name in ['places', 'default', 'virtual_mcp', 'mcp_influxdb']:
                        logger.info(f"[{self.__class__.__name__}] Overriding MCP model '{engine.model_name}' with brain official model '{target_entry.model_name}'")
                        engine.model_name = target_entry.model_name
                else:
                    engine.model_name = self.llm_model
                    
                return engine
            except Exception as e:
                logger.error(f"Failed to initialize MCP brain ({target_provider}): {e}")
                return None
        return None

    def run_reasoning(self, context, goal):
        """Delegates reasoning to the internal brain."""
        if not self._brain:
            return {"insight": "Reasoning brain not initialized for MCP agent.", "actions": []}
        
        logger.info(f"[{self.__class__.__name__}] Delegating reasoning to {self.llm_provider} brain...")
        return self._brain.run_reasoning(context, goal)

    def parse_actions(self, raw_response):
        """Delegates action parsing to the internal brain."""
        if not self._brain:
            return []
        return self._brain.parse_actions(raw_response)
